endpointId=$(curl -sS https://rest.runpod.io/v1/endpoints \
  -H  'Content-Type: application/json'         \
  -H  "Authorization: Bearer $RUNPOD_API_KEY"  \
  -d @- <<DATA     | jq -r .id
{
  "templateId"        : "$templateId",
  "computeType"       : "CPU",
  "cpuFlavorIds"      : [ "cpu3c" ],
  "name"              : "$endpointName",
  "vcpuCount"         :  1,
  "workersMax"        :  1,
  "workersMin"        :  0
}
DATA
)

echo created endpoint with id $endpointId
